# Copy to config/litellm/.env and fill in a real key (scripts/gen-secrets.sh does this).
# .env is gitignored -- never commit the real value.
#
# This key protects the gateway. Every client (Open WebUI, opencode, pi,
# mini-swe-agent) must send it as the OpenAI API key / bearer token.
LITELLM_MASTER_KEY=__LITELLM_MASTER_KEY__
